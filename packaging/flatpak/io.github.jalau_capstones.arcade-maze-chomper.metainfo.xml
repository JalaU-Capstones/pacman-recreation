<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>io.github.jalau_capstones.arcade-maze-chomper</id>
    <name>Arcade Maze Chomper</name>
    <summary>Arcade maze-chase game with multiplayer</summary>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>MIT</project_license>

    <description>
        <p>An arcade-inspired maze-chase game built as an educational project. Navigate mazes, avoid enemies with distinct behaviors, and compete with friends in multiplayer.</p>
        <p>Features:</p>
        <ul>
            <li>Single-player mode with multiple levels</li>
            <li>Multiplayer mode for up to 5 players</li>
            <li>Distinct enemy AI behaviors</li>
            <li>Score tracking and profile system</li>
        </ul>
    </description>

    <launchable type="desktop-id">io.github.jalau_capstones.arcade-maze-chomper.desktop</launchable>

